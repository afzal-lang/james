@model WebApplication1.Models.ContestListViewModel
@{
    ViewData["Title"] = "Contests";
    Layout = "~/Views/Shared/user_layout.cshtml";

    var userId = Context.Session.GetString("UserId");
    bool isLoggedIn = !string.IsNullOrEmpty(userId);
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Contests</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Nunito:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #fef9f2;
            font-family: 'Nunito', sans-serif;
            color: #2c2c2c;
        }

        /* ── Hero Banner ── */
        .contest-hero {
            background: linear-gradient(135deg, #7b3f00 0%, #c0692b 40%, #e8a44a 100%);
            padding: 60px 20px 50px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .contest-hero::before {
                content: "🍽️";
                position: absolute;
                font-size: 180px;
                opacity: 0.06;
                top: -20px;
                left: -30px;
                transform: rotate(-15deg);
            }

            .contest-hero::after {
                content: "🏆";
                position: absolute;
                font-size: 160px;
                opacity: 0.06;
                bottom: -30px;
                right: -20px;
                transform: rotate(10deg);
            }

            .contest-hero h1 {
                font-family: 'Playfair Display', serif;
                font-size: 42px;
                color: #fff;
                letter-spacing: 0.5px;
                margin-bottom: 10px;
            }

            .contest-hero p {
                font-size: 15px;
                color: rgba(255,255,255,0.82);
                font-weight: 400;
                max-width: 480px;
                margin: 0 auto;
                line-height: 1.6;
            }

        /* ── Page wrapper ── */
        .page-wrapper {
            max-width: 1080px;
            margin: 0 auto;
            padding: 44px 20px 60px;
        }

        /* ── Section label ── */
        .section-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

            .section-label span {
                font-family: 'Playfair Display', serif;
                font-size: 22px;
                color: #3d1a00;
            }

            .section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(to right, #d4a03a44, transparent);
            }

        /* ── Grid ── */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
        }

        /* ── Empty state ── */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 70px 20px;
        }

            .empty-state .empty-icon {
                font-size: 52px;
                margin-bottom: 16px;
            }

            .empty-state p {
                color: #999;
                font-size: 15px;
            }

        /* ── Card ── */
        .card {
            background: #fff;
            border: 1px solid #eedfc8;
            border-radius: 14px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            animation: fadeUp 0.4s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(180, 100, 20, 0.13);
        }

        /* coloured top strip based on status */
        .card-strip {
            height: 5px;
            width: 100%;
        }

        .strip-active {
            background: linear-gradient(to right, #27ae60, #82e0aa);
        }

        .strip-upcoming {
            background: linear-gradient(to right, #2980b9, #85c1e9);
        }

        .strip-ended {
            background: linear-gradient(to right, #bbb, #ddd);
        }

        .card-body {
            padding: 20px 22px 18px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex: 1;
        }

        .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 19px;
            color: #1a1a1a;
            line-height: 1.3;
        }

        .card-desc {
            font-size: 13.5px;
            color: #666;
            line-height: 1.6;
        }

        /* ── Date row ── */
        .date-row {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #999;
            margin-top: 2px;
        }

            .date-row svg {
                flex-shrink: 0;
                opacity: 0.6;
            }

        /* ── Status badge ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            width: fit-content;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
        }

        .badge-active {
            background: #eaf7ee;
            color: #1e8449;
        }

            .badge-active .status-dot {
                background: #27ae60;
            }

        .badge-upcoming {
            background: #eaf1fb;
            color: #1a6fa8;
        }

            .badge-upcoming .status-dot {
                background: #2980b9;
            }

        .badge-ended {
            background: #f5f5f5;
            color: #999;
        }

            .badge-ended .status-dot {
                background: #bbb;
            }

        /* ── Card footer ── */
        .card-footer {
            padding: 14px 22px;
            border-top: 1px solid #f3ebe0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
            font-family: 'Nunito', sans-serif;
            transition: opacity 0.2s, transform 0.15s;
        }

            .btn:hover {
                opacity: 0.88;
                transform: translateY(-1px);
            }

            .btn:active {
                transform: translateY(0);
            }

        .btn-submit {
            background: linear-gradient(135deg, #c0692b, #e8a44a);
            color: #fff;
            box-shadow: 0 3px 10px rgba(192, 105, 43, 0.3);
        }

        .status-note {
            font-size: 12.5px;
            color: #aaa;
            font-style: italic;
        }

        .login-note {
            font-size: 12.5px;
            color: #c0692b;
        }

            .login-note a {
                color: #c0692b;
                font-weight: 600;
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <!-- Hero -->
    <div class="contest-hero">
        <h1>Recipe Contests</h1>
        <p>Show off your culinary skills — enter an active contest and let the world taste your creativity.</p>
    </div>

    <div class="page-wrapper">

        <div class="section-label">
            <span>All Contests</span>
        </div>

        <div class="grid">

            @if (Model.Contests == null || !Model.Contests.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">🍳</div>
                    <p>No contests right now. Check back soon!</p>
                </div>
            }
            else
            {
                @foreach (var c in Model.Contests)
                {
                    string status =
                    DateTime.Now < c.StartDate ? "Upcoming" :
                    DateTime.Now > c.EndDate ? "Ended" : "Active";

                    string stripClass =
                    status == "Active" ? "strip-active" :
                    status == "Upcoming" ? "strip-upcoming" : "strip-ended";

                    string badgeClass =
                    status == "Active" ? "badge-active" :
                    status == "Upcoming" ? "badge-upcoming" : "badge-ended";

                    <div class="card" style="animation-delay: @(Model.Contests.ToList().IndexOf(c) * 80)ms">
                        <div class="card-strip @stripClass"></div>

                        <div class="card-body">
                            <div class="card-title">@c.Title</div>
                            <div class="card-desc">@c.Description</div>

                            <div class="date-row">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                                @($"{c.StartDate:dd MMM yyyy} – {c.EndDate:dd MMM yyyy}")
                            </div>

                            <span class="status-badge @badgeClass">
                                <span class="status-dot"></span>
                                @status
                            </span>
                        </div>

                        <div class="card-footer">
                            @if (status == "Active")
                            {
                                if (isLoggedIn)
                                {
                                    <a href="/user/ContestSubmit/@c.ContestId" class="btn btn-submit">
                                        <i class="fa fa-trophy"></i> Submit Entry
                                    </a>
                                }
                                else
                                {
                                    <span class="login-note">
                                        <a href="@Url.Action("Login", "cookies")">Log in</a> to submit
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="status-note">@(status == "Upcoming" ? "Opens soon" : "Contest closed")</span>
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>

</body>

@if (Context.Request.Query["submitted"] == "True")
{
    <div class="modal fade" id="thankYouModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4">
                <div class="mb-3">
                    <i class="fa fa-check-circle text-success" style="font-size:60px;"></i>
                </div>
                <h2 class="text-success">Thank You!</h2>
                <p>Your submission has been received successfully!</p>
                <button class="btn btn-primary mt-3" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var modal = new bootstrap.Modal(document.getElementById('thankYouModal'));
            modal.show();
        });
    </script>
}
</html>
