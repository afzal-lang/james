@model IEnumerable<WebApplication1.Models.Faq>

@{
    ViewData["Title"] = "Faqs";
    Layout = "~/Views/Shared/user_layout.cshtml";
}

<h1>Faqs</h1>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <section class="ftco-section bg-light">
        <div class="container">
            <div class="row justify-content-center mb-5 pb-2">
                <div class="col-md-7 text-center heading-section ftco-animate">
                    <span class="subheading" style="color: #fbaf32; font-family: 'Cookie', cursive; font-size: 30px;">Help Center</span>
                    <h2 class="mb-4">Frequently Asked Questions</h2>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-10">
                    <div class="accordion" id="faqAccordion">
                        @foreach (var item in Model)
                        {
                        <div class="accordion-item mb-3 border-0 shadow-sm">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed py-4" type="button" data-bs-toggle="collapse" data-bs-target="#faq-@item.Faqid" style="font-weight: 600; background: white;">
                                    @item.Question
                                </button>
                            </h2>
                            <div id="faq-@item.Faqid" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body bg-white text-muted">
                                    @item.Answer
                                </div>
                            </div>
                        </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .accordion-button:not(.collapsed) {
            color: #fbaf32 !important;
            background-color: white !important;
            box-shadow: none;
        }
    </style>
