@model IEnumerable<WebApplication1.Models.Recipe>
@{
    Layout = "~/Views/Shared/user_layout.cshtml";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4">@Model.FirstOrDefault()?.Category?.Name Recipes</h2>
    
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-info">@ViewBag.Message</div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
                    <img src="@item.image"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;"
                         onerror="this.src='/images/default.jpg'">                    <div class="card-body">
                        <h5 class="fw-bold">@item.Title</h5>
                        <p class="text-muted small">@item.Description?.Substring(0, Math.Min(item.Description.Length, 50))...</p>
                        <a href="/user/DetailRecipes/@item.RecipeId" class="btn btn-dark w-100 rounded-pill">View Recipe</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>