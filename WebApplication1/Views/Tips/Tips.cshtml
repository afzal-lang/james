@model IEnumerable<WebApplication1.Models.Tip>
@{
    ViewData["Title"] = "Manage Tips";
    Layout = "~/Views/Shared/admin_layout.cshtml";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Manage Recipes Tips</h2>
        <a href="@Url.Action("CreateTip", "Tips")" class="btn btn-primary">+ Add New Tip</a>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Is Free?</th>
                <th>Uploaded By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TipId</td>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>
                        @if (item.IsFree == true)
                        {
                            <span class="badge bg-success">Yes (Free)</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No (Paid)</span>
                        }
                    </td>
                    <td>@item.UploadedBy</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("EditTip", "Tips", new { id = item.TipId })" class="btn btn-sm btn-info text-white">
                                <i class="fa fa-pencil"></i> Edit
                            </a>
                            <a href="@Url.Action("DeleteTip", "Tips", new { id = item.TipId })" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this tip?');">
                                <i class="fa fa-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>