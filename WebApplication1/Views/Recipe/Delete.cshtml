@model WebApplication1.Models.Recipe

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/admin_layout.cshtml";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Recipe</h4>
    <hr />
    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredients)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingredients)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Instructions)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Instructions)
        </dd>

        <dt class="col-sm-2">
            Category
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Category.Name)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsFree)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsFree)
        </dd>

        <dt class="col-sm-2">
            Cooking Time
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CookingTime) mins
        </dd>

        <dt class="col-sm-2">
            Servings
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Servings)
        </dd>

        <dt class="col-sm-2">
            Tags
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Tags)
        </dd>

        <dt class="col-sm-2">
            Nutrition
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nutrition)
        </dd>

        <dt class="col-sm-2">
            Upload Date
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UploadDate)
        </dd>

        <dt class="col-sm-2">
            Image
        </dt>
        <dd class="col-sm-10">
            <img src="~/images/@Model.image" width="120" />
        </dd>

        <dt class="col-sm-2">
            Uploaded By
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UploadedByNavigation.UserID)
        </dd>

    </dl>

    <form method="post" action="/Recipe/DeleteConfirmed/@Model.RecipeId">
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a href="/Recipe/Recipes">Back to List</a>
    </form>
</div>