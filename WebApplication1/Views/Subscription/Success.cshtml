@{
    ViewData["Title"] = "Payment Successful";
    Layout = "~/Views/Shared/user_layout.cshtml";

    string plan = TempData["Plan"]?.ToString() ?? "";
    string amount = TempData["Amount"]?.ToString() ?? "";
    string method = TempData["PaymentMethod"]?.ToString() ?? "";
    string endDate = TempData["EndDate"]?.ToString() ?? "";
}

<style>
    .success-page {
        max-width: 520px;
        margin: 60px auto;
        padding: 0 16px 80px;
        text-align: center;
    }

    .success-anim {
        width: 90px;
        height: 90px;
        background: #dcfce7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.6rem;
        margin: 0 auto 24px;
        animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    @@keyframes popIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .success-page h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .success-page .subtitle {
        color: #64748b;
        font-size: 15px;
        margin-bottom: 32px;
    }

    .receipt-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 28px 24px;
        text-align: left;
        margin-bottom: 28px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .receipt-title {
        font-size: 13px;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 18px;
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
    }

        .receipt-row:last-child {
            border-bottom: none;
        }

        .receipt-row .label {
            color: #64748b;
        }

        .receipt-row .value {
            font-weight: 600;
            color: #0f172a;
        }

            .receipt-row .value.green {
                color: #16a34a;
            }

            .receipt-row .value.blue {
                color: #2563eb;
            }

    .email-note {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 13px;
        color: #1e40af;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-home {
        display: inline-block;
        padding: 14px 36px;
        background: #2563eb;
        color: white;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-home:hover {
            background: #1d4ed8;
            color: white;
        }
</style>

<div class="success-page">

    <div class="success-anim">✅</div>

    <h1>Payment Successful 🎉</h1>
    <p class="subtitle">Your subscription has been activated successfully</p>

    <!-- Receipt -->
    <div class="receipt-card">
        <div class="receipt-title">📄 Payment Receipt</div>

        <div class="receipt-row">
            <span class="label">Plan</span>
            <span class="value blue">@plan Plan</span>
        </div>

        <div class="receipt-row">
            <span class="label">Amount Paid</span>
            <span class="value">$@amount</span>
        </div>

        <div class="receipt-row">
            <span class="label">Payment Method</span>
            <span class="value">
                @(method == "EasyPaisa" ? "🟢" : "🔴") @method
            </span>
        </div>

        <div class="receipt-row">
            <span class="label">Status</span>
            <span class="value green">Active</span>
        </div>

        <div class="receipt-row">
            <span class="label">Valid Until</span>
            <span class="value">@endDate</span>
        </div>
    </div>

    <!-- Email Note -->
    <div class="email-note">
        <span style="font-size:1.4rem">📧</span>
        <span>
            A confirmation email has been sent to your registered email address. Please check your inbox.
        </span>
    </div>

    <a href="/user/ShowRecipes" class="btn-home">🏠 Go to Home</a>

</div>