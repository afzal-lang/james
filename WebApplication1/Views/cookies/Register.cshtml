@model WebApplication1.Models.User

@{
    ViewData["Title"] = "Register";
    Layout = null;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

</head>
<body>

    <div class="container-main">

   

        <!-- RIGHT FORM -->
        <div class="right-side">
            <div class="register-card">

                <h2>Sign Up</h2>

                @if (ViewBag.msg != null)
                {
                    <div class="alert alert-danger">@ViewBag.msg</div>
                }

                <form asp-action="Register" method="post">

                    <div class="mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Full Name" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email Address" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    </div>

                    <div class="mt-3">
                        <input type="submit" value="Register" class="btn btn-custom" />
                    </div>

                </form>

                <hr />

                <div class="text-center button mt-2" >
                    <a asp-action="Login">Already have an account? Login</a>
                </div>

            </div>
        </div>

    </div>

</body>
</html>